
\usepackage[margin=1in]{geometry}
\usepackage{amsmath}
\usepackage{graphicx}
\usepackage{amssymb}
\usepackage[dvipsnames]{xcolor}
\usepackage{fancyvrb}
\usepackage{listings}

\usepackage[backend=bibtex]{biblatex}



% Generic colors
\definecolor{codegreen}{rgb}{0,0.6,0}
\definecolor{codepurple}{rgb}{0.58,0,0.82}
\definecolor{backcolour}{rgb}{0.95,0.95,0.92}

% C++ Style
\lstdefinestyle{cppstyle}{
    language=C++,
    backgroundcolor=\color{backcolour},
    commentstyle=\color{codegreen},
    keywordstyle=\color{magenta},
    basicstyle=\ttfamily\small,
    % Line numbering settings:
    numbers=left,                    
    numbersep=10pt,                  
    numberstyle=\tiny\color{black},
    breaklines=true
}

% Assembly Style (x86/x64)
\lstdefinestyle{asmstyle}{
    language=[x86masm]Assembler,
    backgroundcolor=\color{white},
    commentstyle=\color{orange},
    keywordstyle=\color{red},
    basicstyle=\ttfamily\small,
    stepnumber=1,
    breaklines=true
}

% Bash/Terminal Style
\lstdefinestyle{bashstyle}{
    language=bash,
    backgroundcolor=\color{backcolour},
    basicstyle=\ttfamily\small\color{black},
    keywordstyle=\color{cyan},
    showstringspaces=false,
    breaklines=true
}

% SystemVerilog Style
\lstdefinestyle{svstyle}{
    language=Verilog,
    backgroundcolor=\color{backcolour},
    commentstyle=\color{codegreen}\itshape,
    keywordstyle=\color{blue}\bfseries,
    keywordstyle=[2]\color{codepurple}\bfseries,
    stringstyle=\color{BrickRed},
    basicstyle=\ttfamily\small,
    numbers=left,
    numbersep=10pt,
    numberstyle=\tiny\color{black},
    breaklines=true,
    showstringspaces=false,
    morekeywords={
        logic, bit, byte, shortint, int, longint, chandle, string,
        typedef, enum, struct, union, packed, tagged,
        interface, endinterface, modport, clocking, endclocking,
        program, endprogram, package, endpackage, import,
        class, endclass, extends, implements, virtual, pure, extern,
        new, null, this, super, local, protected, rand, randc,
        constraint, solve, before, dist, inside,
        covergroup, endgroup, coverpoint, cross, bins, illegal_bins,
        sequence, endsequence, property, endproperty,
        assert, assume, cover, expect, throughout, within,
        always_ff, always_comb, always_latch, unique, priority,
        iff, matches, tagged, void, ref, const, static, automatic
    },
    morekeywords=[2]{
        posedge, negedge
    },
    literate={|=>}{{{\color{codepurple}\bfseries|=>}}}3
             {|->}{{{\color{codepurple}\bfseries|->}}}3
             {\#\#}{{{\color{codepurple}\bfseries\#\#}}}2
}

% Python Style
\lstdefinestyle{pythonstyle}{
    language=Python,
    backgroundcolor=\color{backcolour},
    commentstyle=\color{codegreen}\itshape,
    keywordstyle=\color{blue}\bfseries,
    stringstyle=\color{codepurple},
    basicstyle=\ttfamily\small,
    numbers=left,
    numbersep=10pt,
    numberstyle=\tiny\color{black},
    breaklines=true,
    showstringspaces=false,
    morekeywords={self, True, False, None, as, with, yield, lambda}
}
